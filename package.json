{
  "name": "nu-eats",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server.js",
    "start": "node server.js",
    "db:init": "python django_db/db_bridge.py init",
    "django:check": "python django_db/manage.py check",
    "dev:all": "concurrently \"npm run server\" \"npm run dev\"",
